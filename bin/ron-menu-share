#!/usr/bin/env fish

set selected (
    printf  "î«° files (fuzzy)\nî«° files (explorer)\nó°…Ś clipboard" \
    | fuzzel --dmenu --minimal-lines --prompt "share> " \
    | cut -d' ' -f2-
)

switch $selected
    case "files (fuzzy)"
        xdg-terminal-exec --app-id=ron.terminal.floating ron-share files
    case "files (explorer)"
        xdg-terminal-exec --app-id=ron.terminal.floating ron-share --picker explorer files
    case clipboard
        ron-share clipboard
end
