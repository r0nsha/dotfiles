#!/usr/bin/env fish
# Changes the wallpaper to the given image and updates the updates the desktop according to the wallpaper's colors.

set img $argv[1]
awww img --resize=crop "$img" --transition-fps=120 --transition-duration=1.5 --transition-type=random

# link to cache so that other apps can reference it
ln -sf "$img" ~/.cache/current_background

ron-theme-generate
